# ============================================================
# AI Calling Agent — Environment Template
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control!
# ============================================================

# ── Server ───────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=localhost
LOG_LEVEL=info

# ── Vobiz (Indian Cloud Telephony) ───────────────────────────
# Required — must match your Vobiz account credentials
VOBIZ_AUTH_ID=your_auth_id_here
VOBIZ_AUTH_TOKEN=your_auth_token_here
VOBIZ_CALLER_ID=+91XXXXXXXXXX
# Public URL Vobiz will POST webhooks to (use ngrok in dev)
BASE_URL=https://your-ngrok-url.ngrok.io

# ── STT — Deepgram ────────────────────────────────────────────
# https://console.deepgram.com → API Keys
# Used in: src/services/stt.js
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# ── TTS — Sarvam AI ───────────────────────────────────────────
# https://dashboard.sarvam.ai → API Keys
# Used in: src/services/tts.js
SARVAM_API_KEY=your_sarvam_api_key_here

# ── LLM — Gemini (primary) ────────────────────────────────────
# https://aistudio.google.com → Get API Key
# Used in: src/services/llm.js (primary)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ── LLM — OpenAI (fallback only) ─────────────────────────────
# Only used if Gemini fails
# Used in: src/services/llm.js (fallback)
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini

# ── MongoDB ───────────────────────────────────────────────────
# Atlas connection string — GridFS storage is auto-enabled
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/ai_outbound?retryWrites=true&w=majority

# ── Email — Gmail SMTP with App Password ─────────────────────
# How to get app password: Google Account → Security → 2-Step Verification → App passwords
# Used in: src/services/mailer.js
GMAIL_USER=yourname@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Real Estate Agent Identity ────────────────────────────────
COMPANY_NAME=Your Company Name
AGENT_NAME=Priya
SYSTEM_PROMPT_FILE=config/ai_calling_agent_system_prompt.txt

# ── Language ──────────────────────────────────────────────────
# Available: en-IN, hi-IN, ta-IN, te-IN, bn-IN, mr-IN, kn-IN, gu-IN, ml-IN
DEFAULT_LANGUAGE=en-IN
SUPPORTED_LANGUAGES=en-IN,hi-IN,ta-IN,te-IN,bn-IN,mr-IN,kn-IN,gu-IN,ml-IN

# ── Cost & Call Limits ────────────────────────────────────────
CALL_MAX_MINUTES=10
CAMPAIGN_MONTHLY_BUDGET=10000
TARGET_COST_PER_MIN_RS=2

# ── Pipeline Tuning (leave defaults for most deployments) ─────
VAD_THRESHOLD=0.01
BARGE_IN_MIN_PLAYBACK_MS=1500
BARGE_IN_REQUIRED_CHUNKS=10
BARGE_IN_RMS_MULTIPLIER=2.5
SPEECH_START_CHUNKS=1
SPEECH_END_CHUNKS=8
MIN_UTTERANCE_BYTES=2400
SILENCE_PROMPT_MS=7000

# ── TTS Cache ─────────────────────────────────────────────────
TTS_CACHE_MAX_ENTRIES=100
TTS_CACHE_MAX_BYTES=3145728

# ── Auth ──────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-strong-random-secret
GOOGLE_CLIENT_ID=your-google-oauth-client-id
