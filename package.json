{
  "name": "ai-outbound-agent",
  "version": "2.0.0",
  "private": true,
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --runInBand --forceExit",
    "test:ci": "jest --runInBand --forceExit --ci --coverage",
    "healthcheck": "curl -sf http://localhost:3000/health/ready",
    "load-test": "node scripts/load-test.js --connections=10 --duration=30",
    "load-test:100": "node scripts/load-test.js --connections=100 --duration=60",
    "docker:build": "docker build -t ai-calling-agent:latest .",
    "docker:run": "docker compose up -d",
    "docker:stop": "docker compose down",
    "docker:logs": "docker compose logs -f app",
    "ingest-campaign": "node scripts/ingestCampaign.js",
    "mock-test": "node scripts/mock-test.js",
    "mock-test:objection": "node scripts/mock-test.js --scenario=objection",
    "mock-test:hindi": "node scripts/mock-test.js --scenario=hindi --lang=hi-IN",
    "mock-test:tricky": "node scripts/mock-test.js --scenario=tricky",
    "stress-test": "node scripts/stress-test.js",
    "stress-test:10": "node scripts/stress-test.js --calls=10 --turns=4",
    "stress-test:20": "node scripts/stress-test.js --calls=20 --turns=3"
  },
  "engines": {
    "node": "20.x"
  },
  "dependencies": {
    "@deepgram/sdk": "^5.0.0",
    "axios": "^1.4.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^16.0.0",
    "express": "^4.18.2",
    "express-ws": "^5.0.2",
    "form-data": "^4.0.0",
    "google-auth-library": "^10.5.0",
    "jsonwebtoken": "^9.0.3",
    "mime-types": "^2.1.35",
    "mongoose": "^7.0.0",
    "multer": "^2.1.0",
    "nodemailer": "^8.0.3",
    "openai": "^6.22.0",
    "uuid": "^9.0.0",
    "wav": "^1.0.2",
    "wavefile": "^11.0.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "jest": "^29.6.0",
    "nodemon": "^2.0.22",
    "supertest": "^6.3.3"
  }
}
