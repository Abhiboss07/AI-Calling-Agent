# Normalize all text files to LF in the repo (prevents CRLF diff noise from
# Windows edits). Binary files are auto-detected and left untouched.
* text=auto eol=lf

# Explicitly treat common source/config as LF text
*.js    text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.txt   text eol=lf
*.env   text eol=lf
*.conf  text eol=lf
Dockerfile text eol=lf

# Binary assets — never touch
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.wav   binary
*.mp3   binary
*.pdf   binary
